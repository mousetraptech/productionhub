<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kmfa.node-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/kmfa/productionhub/node-agent/.venv/bin/python3</string>
        <string>-m</string>
        <string>agent.main</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/opt/kmfa/productionhub/node-agent</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/opt/kmfa/productionhub/node-agent/node-agent.log</string>

    <key>StandardErrorPath</key>
    <string>/opt/kmfa/productionhub/node-agent/node-agent.log</string>
</dict>
</plist>
